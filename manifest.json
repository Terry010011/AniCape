{
  "id": "/",
  "name": "AniCape - Minecraft Animated Cape Maker",
  "short_name": "AniCape",
  "description": "Create amazing animated capes for Minecraft easily.",
  "start_url": "index.html",
  "display": "standalone",
  "background_color": "#f4f4f7",
  "theme_color": "#ffffff",
  "icons": [
    {
      "src": "./assets/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml"
    },
    {
      "src": "./assets/favicon.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "./assets/favicon.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "orientation": "any",
  "scope": "./",
  "file_handlers": [
    {
      "action": "index.html",
      "accept": {
        "application/x-anicape": [
          ".anicape"
        ]
      },
      "icons": [
        {
          "src": "./assets/favicon.svg",
          "sizes": "512x512",
          "type": "image/svg+xml"
        }
      ],
      "launch_type": "single-client"
    }
  ]
}